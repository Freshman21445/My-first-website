<!DOCTYPE html>
<html>

<head>
  <title>Exam System</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: Arial, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      padding: 20px;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
    }

    h1 {
      text-align: center;
      color: white;
      margin-bottom: 30px;
      font-size: 2.5em;
    }

    #msg {
      text-align: center;
      font-size: 1.2em;
      margin-bottom: 20px;
      padding: 10px;
      border-radius: 5px;
      min-height: 20px;
    }

    /* AUTH BOX STYLES */
    #authBox {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 80vh;
    }

    .auth-box {
      background: white;
      padding: 40px;
      border-radius: 10px;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
      width: 100%;
      max-width: 400px;
    }

    .auth-box h2 {
      margin-bottom: 30px;
      color: #333;
      text-align: center;
    }

    .auth-box input {
      width: 100%;
      padding: 12px;
      margin-bottom: 15px;
      border: 1px solid #ddd;
      border-radius: 5px;
      font-size: 1em;
    }

    .auth-box input:focus {
      outline: none;
      border-color: #667eea;
      box-shadow: 0 0 5px rgba(102, 126, 234, 0.3);
    }

    .auth-box button {
      width: 100%;
      padding: 12px;
      background: #667eea;
      color: white;
      border: none;
      border-radius: 5px;
      font-size: 1em;
      cursor: pointer;
      margin-bottom: 15px;
      transition: background 0.3s;
    }

    .auth-box button:hover {
      background: #764ba2;
    }

    .auth-box p {
      text-align: center;
      margin: 20px 0 10px;
      color: #666;
    }

    /* DASHBOARD STYLES */
    #examBox {
      display: none;
    }

    .dashboard-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
      background: white;
      padding: 20px;
      border-radius: 10px;
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }

    .dashboard-header h2 {
      color: #333;
      font-size: 1.8em;
    }

    .logout-btn {
      padding: 10px 20px;
      background: #e74c3c;
      color: white;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      font-size: 1em;
      transition: background 0.3s;
    }

    .logout-btn:hover {
      background: #c0392b;
    }

    /* COURSES ROW */
    .courses-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 25px;
      margin-top: 30px;
      margin-bottom: 40px;
    }

    .course-card {
      background: white;
      border-radius: 10px;
      padding: 25px;
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
      transition: transform 0.3s, box-shadow 0.3s;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 20px;
      min-height: 320px;
      cursor: pointer;
      justify-content: flex-start;
    }

    .course-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    }

    .course-icon {
      font-size: 3em;
      flex-shrink: 0;
    }

    .course-info {
      flex: 1;
      text-align: center;
      width: 100%;
    }

    .course-card h3 {
      color: #333;
      margin-bottom: 5px;
      font-size: 1.3em;
    }

    .course-card p {
      color: #666;
      font-size: 0.9em;
      margin-bottom: 0;
    }

    .course-buttons {
      display: flex;
      gap: 10px;
      flex-shrink: 0;
      width: 100%;
      justify-content: center;
    }

    .material-btn,
    .exam-btn {
      padding: 10px 15px;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      font-size: 0.9em;
      transition: background 0.3s;
      white-space: nowrap;
      flex: 1;
    }

    .material-btn {
      background: #3498db;
      color: white;
    }

    .material-btn:hover {
      background: #2980b9;
    }

    .exam-btn {
      background: #27ae60;
      color: white;
    }

    .exam-btn:hover {
      background: #229954;
    }

    /* EXPANDED COURSE MODAL */
    #courseModal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.6);
      z-index: 1000;
      justify-content: center;
      align-items: center;
      padding: 20px;
    }

    .modal-content {
      background: white;
      border-radius: 15px;
      padding: 40px;
      max-width: 500px;
      width: 100%;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
      text-align: center;
      animation: slideIn 0.3s ease-out;
    }

    @keyframes slideIn {
      from {
        transform: translateY(-50px);
        opacity: 0;
      }
      to {
        transform: translateY(0);
        opacity: 1;
      }
    }

    .modal-content h2 {
      color: #333;
      margin-bottom: 10px;
      font-size: 1.8em;
    }

    .modal-content p {
      color: #666;
      margin-bottom: 30px;
      font-size: 1em;
    }

    .modal-buttons {
      display: flex;
      gap: 20px;
      justify-content: center;
    }

    .modal-material-btn,
    .modal-exam-btn,
    .modal-close-btn {
      padding: 12px 30px;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      font-size: 1em;
      font-weight: bold;
      transition: all 0.3s;
      flex: 1;
    }

    .modal-material-btn {
      background: #3498db;
      color: white;
    }

    .modal-material-btn:hover {
      background: #2980b9;
      transform: scale(1.05);
    }

    .modal-exam-btn {
      background: #27ae60;
      color: white;
    }

    .modal-exam-btn:hover {
      background: #229954;
      transform: scale(1.05);
    }

    .modal-close-btn {
      background: #95a5a6;
      color: white;
      width: 100%;
    }

    .modal-close-btn:hover {
      background: #7f8c8d;
    }

    /* MATERIAL SECTION */
    #materialSection {
      display: none;
      background: white;
      padding: 30px;
      border-radius: 10px;
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
      margin-bottom: 40px;
    }

    .material-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }

    .material-header h2 {
      color: #333;
      font-size: 1.8em;
    }

    .close-material-btn {
      padding: 10px 20px;
      background: #95a5a6;
      color: white;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      font-size: 1em;
    }

    .close-material-btn:hover {
      background: #7f8c8d;
    }

    .material-content {
      background: #f8f9fa;
      padding: 20px;
      border-radius: 5px;
      line-height: 1.8;
      color: #333;
    }

    /* EXAM SECTION */
    #examSection {
      display: none;
      background: white;
      padding: 30px;
      border-radius: 10px;
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }

    .exam-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }

    .exam-header h2 {
      color: #333;
      font-size: 1.8em;
    }

    .close-exam-btn {
      padding: 10px 20px;
      background: #95a5a6;
      color: white;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      font-size: 1em;
    }

    .close-exam-btn:hover {
      background: #7f8c8d;
    }

    .exam-content {
      background: #f8f9fa;
      padding: 20px;
      border-radius: 5px;
    }

    .question {
      margin-bottom: 30px;
      padding: 15px;
      background: white;
      border-left: 4px solid #667eea;
      border-radius: 5px;
    }

    .question-text {
      font-weight: bold;
      margin-bottom: 10px;
      color: #333;
    }

    .options {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .option {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .option input[type="radio"] {
      cursor: pointer;
    }

    .option label {
      cursor: pointer;
      flex: 1;
    }

    .submit-exam-btn {
      padding: 12px 30px;
      background: #27ae60;
      color: white;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      font-size: 1em;
      margin-top: 20px;
      transition: background 0.3s;
    }

    .submit-exam-btn:hover {
      background: #229954;
    }
  </style>

  <script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/12.13.0/firebase-app.js";
    import { getFirestore, collection, query, where, getDocs, addDoc } 
    from "https://www.gstatic.com/firebasejs/12.13.0/firebase-firestore.js";

    const firebaseConfig = {
      apiKey: "AIzaSyAavkqPwNgzo3UASsz-feaQvTjobxwkj-s",
      authDomain: "student-quiz-platform-9439a.firebaseapp.com",
      projectId: "student-quiz-platform-9439a",
      storageBucket: "student-quiz-platform-9439a.firebasestorage.app",
      messagingSenderId: "815750551646",
      appId: "1:815750551646:web:1c48edb729252bd667bccf"
    };

    const app = initializeApp(firebaseConfig);
    const db = getFirestore(app);

    // LOGIN
    window.login = async function () {
      let phone = document.getElementById("loginPhone").value;
      let password = document.getElementById("loginPassword").value;

      const q = query(
        collection(db, "users"),
        where("phone", "==", phone),
        where("password", "==", password)
      );

      const snap = await getDocs(q);

      if (!snap.empty) {
        document.getElementById("msg").innerHTML = "✔ Welcome! Login successful";
        document.getElementById("authBox").style.display = "none";
        document.getElementById("examBox").style.display = "block";
      } else {
        document.getElementById("msg").innerHTML = "❌ Wrong phone or password";
      }
    };

    // REGISTER
    window.register = async function () {
      let phone = document.getElementById("regPhone").value;
      let password = document.getElementById("regPassword").value;

      if (!phone || !password) {
        document.getElementById("msg").innerHTML = "❌ Please fill all fields";
        return;
      }

      await addDoc(collection(db, "users"), {
        phone: phone,
        password: password
      });

      document.getElementById("msg").innerHTML = "✔ Registered successfully! Now login";
      showLogin();
    };

    // UI SWITCH
    window.showRegister = function () {
      document.getElementById("loginBox").style.display = "none";
      document.getElementById("registerBox").style.display = "block";
    };

    window.showLogin = function () {
      document.getElementById("registerBox").style.display = "none";
      document.getElementById("loginBox").style.display = "block";
    };

    // LOGOUT
    window.logout = function () {
      document.getElementById("authBox").style.display = "flex";
      document.getElementById("examBox").style.display = "none";
      document.getElementById("msg").innerHTML = "";
      document.getElementById("loginPhone").value = "";
      document.getElementById("loginPassword").value = "";
      document.getElementById("regPhone").value = "";
      document.getElementById("regPassword").value = "";
      closeMaterial();
      closeExam();
    };

  </script>

</head>

<body>

<div class="container">

  <h1>📚 Online Exam System</h1>

  <p id="msg"></p>

  <div id="authBox">

    <!-- LOGIN -->
    <div id="loginBox" class="auth-box">
      <h2>Login</h2>
      <input id="loginPhone" placeholder="Phone" type="text"><br>
      <input id="loginPassword" type="password" placeholder="Password"><br>
      <button onclick="login()">Login</button><br>

      <p>Don't have an account?</p>
      <button onclick="showRegister()">Register</button>
    </div>

    <!-- REGISTER -->
    <div id="registerBox" class="auth-box" style="display:none;">
      <h2>Register</h2>
      <input id="regPhone" placeholder="Phone" type="text"><br>
      <input id="regPassword" type="password" placeholder="Password"><br>
      <button onclick="register()">Create Account</button><br>

      <p>Already have account?</p>
      <button onclick="showLogin()">Login</button>
    </div>

  </div>

  <!-- DASHBOARD -->
  <div id="examBox">
    <div class="dashboard-header">
      <h2>📖 Available Courses</h2>
      <button class="logout-btn" onclick="logout()">Logout</button>
    </div>

    <!-- ROW 1: COURSES -->
    <div class="courses-grid">
      <!-- Anthropology -->
      <div class="course-card" onclick="openCourseModal('Anthropology', '🧬')">
        <div class="course-icon">🧬</div>
        <div class="course-info">
          <h3>Anthropology</h3>
          <p>Study of human cultures and societies</p>
        </div>
      </div>

      <!-- Emerging Technology -->
      <div class="course-card" onclick="openCourseModal('Emerging Technology', '💻')">
        <div class="course-icon">💻</div>
        <div class="course-info">
          <h3>Emerging Technology</h3>
          <p>Latest developments in technology</p>
        </div>
      </div>

      <!-- Entrepreneurship -->
      <div class="course-card" onclick="openCourseModal('Entrepreneurship', '🚀')">
        <div class="course-icon">🚀</div>
        <div class="course-info">
          <h3>Entrepreneurship</h3>
          <p>Learn business creation skills</p>
        </div>
      </div>

      <!-- Applied Mathematics -->
      <div class="course-card" onclick="openCourseModal('Applied Mathematics', '📐')">
        <div class="course-icon">📐</div>
        <div class="course-info">
          <h3>Applied Mathematics</h3>
          <p>Mathematics in real-world applications</p>
        </div>
      </div>

      <!-- Computer Programming -->
      <div class="course-card" onclick="openCourseModal('Computer Programming', '⌨️')">
        <div class="course-icon">⌨️</div>
        <div class="course-info">
          <h3>Computer Programming</h3>
          <p>Learn coding and software development</p>
        </div>
      </div>

      <!-- English -->
      <div class="course-card" onclick="openCourseModal('English', '📝')">
        <div class="course-icon">📝</div>
        <div class="course-info">
          <h3>English</h3>
          <p>Language and communication skills</p>
        </div>
      </div>

      <!-- History of Ethiopia and the Horn -->
      <div class="course-card" onclick="openCourseModal('History of Ethiopia and the Horn', '🏛️')">
        <div class="course-icon">🏛️</div>
        <div class="course-info">
          <h3>History of Ethiopia and the Horn</h3>
          <p>Regional history and heritage</p>
        </div>
      </div>

      <!-- Moral and Civic Education -->
      <div class="course-card" onclick="openCourseModal('Moral and Civic Education', '⚖️')">
        <div class="course-icon">⚖️</div>
        <div class="course-info">
          <h3>Moral and Civic Education</h3>
          <p>Ethics and citizenship values</p>
        </div>
      </div>
    </div>

    <!-- COURSE MODAL -->
    <div id="courseModal">
      <div class="modal-content">
        <h2 id="modalTitle"></h2>
        <p id="modalDescription"></p>
        <div class="modal-buttons">
          <button class="modal-material-btn" onclick="handleMaterialClick()">📖 Material</button>
          <button class="modal-exam-btn" onclick="handleExamClick()">✏️ Exam</button>
        </div>
        <br>
        <button class="modal-close-btn" onclick="closeCourseModal()">Close</button>
      </div>
    </div>

    <!-- ROW 2: MATERIAL SECTION -->
    <div id="materialSection">
      <div class="material-header">
        <h2 id="materialTitle">📚 Course Material</h2>
        <button class="close-material-btn" onclick="closeMaterial()">Close</button>
      </div>
      <div id="materialContent" class="material-content">
        <!-- Material will be loaded here -->
      </div>
    </div>

    <!-- ROW 3: EXAM SECTION -->
    <div id="examSection">
      <div class="exam-header">
        <h2 id="examTitle">✏️ Exam</h2>
        <button class="close-exam-btn" onclick="closeExam()">Close</button>
      </div>
      <div id="examContent" class="exam-content">
        <!-- Exam will be loaded here -->
      </div>
    </div>

  </div>

</div>

<script>
  // Course materials data
  const coursesMaterials = {
    'Anthropology': 'Anthropology is the study of human societies, cultures, and their behaviors. Topics include: Cultural practices, Social structures, Evolution of human societies, and Ethnographic studies. Learn how different societies organize themselves and develop culturally distinct practices over time.',
    'Emerging Technology': 'Emerging Technology covers the latest innovations including: Artificial Intelligence, Machine Learning, Blockchain, Internet of Things (IoT), Cloud Computing, and Quantum Computing. Explore cutting-edge technologies shaping the future.',
    'Entrepreneurship': 'Entrepreneurship teaches business creation and management: Business planning, Market analysis, Financial management, Risk assessment, and Scaling strategies. Learn how to turn ideas into successful businesses.',
    'Applied Mathematics': 'Applied Mathematics includes: Calculus, Linear Algebra, Differential Equations, Statistics, and their applications in engineering and science. Understand how mathematical concepts solve real-world problems.',
    'Computer Programming': 'Computer Programming fundamentals: Variables and data types, Control structures, Functions, Object-oriented programming, and Data structures. Master the skills needed for software development.',
    'English': 'English language skills: Grammar and syntax, Vocabulary development, Reading comprehension, Writing skills, and Communication techniques. Enhance your ability to communicate effectively.',
    'History of Ethiopia and the Horn': 'History covering: Ancient kingdoms, Colonial period, Medieval era, Modern political developments, and Cultural heritage of the region. Understand the rich history of Ethiopia and the Horn of Africa.',
    'Moral and Civic Education': 'Values and ethics: Citizenship responsibilities, Democratic principles, Human rights, Social responsibility, and ethical decision-making. Learn about ethical foundations of society.'
  };

  const courseDescriptions = {
    'Anthropology': 'Study of human cultures and societies',
    'Emerging Technology': 'Latest developments in technology',
    'Entrepreneurship': 'Learn business creation skills',
    'Applied Mathematics': 'Mathematics in real-world applications',
    'Computer Programming': 'Learn coding and software development',
    'English': 'Language and communication skills',
    'History of Ethiopia and the Horn': 'Regional history and heritage',
    'Moral and Civic Education': 'Ethics and citizenship values'
  };

  let currentCourse = '';

  // Open course modal
  window.openCourseModal = function (courseName, icon) {
    currentCourse = courseName;
    document.getElementById('modalTitle').innerHTML = icon + ' ' + courseName;
    document.getElementById('modalDescription').innerHTML = courseDescriptions[courseName];
    document.getElementById('courseModal').style.display = 'flex';
  };

  // Close course modal
  window.closeCourseModal = function () {
    document.getElementById('courseModal').style.display = 'none';
    currentCourse = '';
  };

  // Handle material click from modal
  window.handleMaterialClick = function () {
    closeCourseModal();
    showMaterial(currentCourse);
  };

  // Handle exam click from modal
  window.handleExamClick = function () {
    closeCourseModal();
    showExam(currentCourse);
  };

  // Show material section
  window.showMaterial = function (courseName) {
    document.getElementById('materialTitle').innerHTML = '📚 ' + courseName + ' - Material';
    document.getElementById('materialContent').innerHTML = coursesMaterials[courseName] || 'No material available';
    document.getElementById('materialSection').style.display = 'block';
    document.getElementById('examSection').style.display = 'none';
    window.scrollTo(0, document.getElementById('materialSection').offsetTop);
  };

  // Close material section
  window.closeMaterial = function () {
    document.getElementById('materialSection').style.display = 'none';
  };

  // Show exam section
  window.showExam = function (courseName) {
    document.getElementById('examTitle').innerHTML = '✏️ ' + courseName + ' - Exam';
    
    // Sample exam questions
    const examHTML = `
      <div class="question">
        <div class="question-text">1. What is the main focus of ${courseName}?</div>
        <div class="options">
          <div class="option">
            <input type="radio" name="q1" value="a">
            <label>Option A</label>
          </div>
          <div class="option">
            <input type="radio" name="q1" value="b">
            <label>Option B</label>
          </div>
          <div class="option">
            <input type="radio" name="q1" value="c">
            <label>Option C</label>
          </div>
          <div class="option">
            <input type="radio" name="q1" value="d">
            <label>Option D</label>
          </div>
        </div>
      </div>

      <div class="question">
        <div class="question-text">2. Which of the following is a key concept in ${courseName}?</div>
        <div class="options">
          <div class="option">
            <input type="radio" name="q2" value="a">
            <label>Option A</label>
          </div>
          <div class="option">
            <input type="radio" name="q2" value="b">
            <label>Option B</label>
          </div>
          <div class="option">
            <input type="radio" name="q2" value="c">
            <label>Option C</label>
          </div>
          <div class="option">
            <input type="radio" name="q2" value="d">
            <label>Option D</label>
          </div>
        </div>
      </div>

      <div class="question">
        <div class="question-text">3. What is an important application of ${courseName}?</div>
        <div class="options">
          <div class="option">
            <input type="radio" name="q3" value="a">
            <label>Option A</label>
          </div>
          <div class="option">
            <input type="radio" name="q3" value="b">
            <label>Option B</label>
          </div>
          <div class="option">
            <input type="radio" name="q3" value="c">
            <label>Option C</label>
          </div>
          <div class="option">
            <input type="radio" name="q3" value="d">
            <label>Option D</label>
          </div>
        </div>
      </div>

      <button class="submit-exam-btn" onclick="submitExam('${courseName}')">Submit Exam</button>
    `;

    document.getElementById('examContent').innerHTML = examHTML;
    document.getElementById('examSection').style.display = 'block';
    document.getElementById('materialSection').style.display = 'none';
    window.scrollTo(0, document.getElementById('examSection').offsetTop);
  };

  // Close exam section
  window.closeExam = function () {
    document.getElementById('examSection').style.display = 'none';
  };

  // Submit exam
  window.submitExam = function (courseName) {
    alert('Exam submitted for ' + courseName + '!\n\nThank you for completing the exam.');
    closeExam();
  };

  // Close modal when clicking outside
  window.onclick = function (event) {
    const modal = document.getElementById('courseModal');
    if (event.target === modal) {
      closeCourseModal();
    }
  };
</script>

</body>
</html>
